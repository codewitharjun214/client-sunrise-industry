{
  "entities": {
    "Inquiry": {
      "title": "Inquiry",
      "description": "A contact inquiry from a user.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique ID of the inquiry." },
        "name": { "type": "string", "description": "Name of the person." },
        "email": { "type": "string", "format": "email", "description": "Email address." },
        "phone": { "type": "string", "description": "Phone number." },
        "division": { "type": "string", "description": "Division of interest." },
        "message": { "type": "string", "description": "Message content." },
        "date": { "type": "string", "description": "Date of inquiry." },
        "createdAt": { "type": "number", "description": "Timestamp of creation." }
      },
      "required": ["name", "email", "message", "date", "createdAt"]
    }
  },
  "firestore": {
    "/inquiries/{inquiryId}": {
      "schema": "Inquiry",
      "description": "Collection of contact inquiries."
    }
  }
}
